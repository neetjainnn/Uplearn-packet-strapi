{
  "kind": "collectionType",
  "collectionName": "packets",
  "info": {
    "singularName": "packet",
    "pluralName": "packets",
    "displayName": "Packet",
    "description": "Structured collection of courses based on different stock market topics"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "shortDescription": {
      "type": "text",
      "required": true
    },
    "visualPreview": {
      "type": "string",
      "regex": "^(https?:\\/\\/)?(www\\.)?(youtube\\.com|youtu\\.be)\\/.+$"
    },
    "packetPrice": {
      "type": "decimal",
      "required": true,
      "default": 0,
      "min": 0
    },
    "whatYouWillBeAbleToDo": {
      "type": "component",
      "repeatable": true,
      "component": "packet.pointer"
    },
    "levels": {
      "type": "component",
      "repeatable": true,
      "component": "packet.level"
    },
    "mentors": {
      "type": "component",
      "repeatable": true,
      "component": "packet.mentor"
    },
    "totalCourses": {
      "type": "integer",
      "default": 0
    },
    "totalContentHours": {
      "type": "decimal",
      "default": 0
    },
    "totalLevels": {
      "type": "integer",
      "default": 0
    },
    "totalFreeCourses": {
      "type": "integer",
      "default": 0
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    }
  }
}
